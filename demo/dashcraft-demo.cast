[136.209518, "o", "\u001b[2;24r\u001b[2;24r\u001b[125;248s\u001b[1;1H\u001b[13S\u001b[2;24r\u001b[s\u001b[11;125H    ruff format: --- src/charm.py\u001b[12;125H    ruff format: +++ src/charm.py\u001b[K\u001b[13;125H    ruff format: @@ -58,9 +58,7 @@\u001b[K\u001b[14;125H    ruff format:          \"\"\"Check whether the workload is ready to use.\"\"\"\u001b[K\u001b[15;125H    ruff format:          for name, service_info in self.container.get_services().items():\u001b[K\u001b[16;125H    ruff format:              if not service_info.is_running():\u001b[K\u001b[17;125H    ruff format: -                logger.info(\u001b[K\u001b[18;125H    ruff format: -                    \"the workload is not ready (service '%s' is not running)\", name\u001b[K\u001b[19;125H    ruff format: -                )\u001b[K\u001b[20;125H    ruff format: +                logger.info(\"the workload is not ready (service '%s' is not running)\", name)\u001b[K\u001b[21;125H    ruff format:                  return False\u001b[K\u001b[22;125H    ruff format:          checks = self.container.get_checks(level=ops.pebble.CheckLevel.READY)\u001b[K\u001b[23;125H    ruff format:          for check_info in checks.values():\u001b[K\u001b[24;125H\u001b[K\u001b[1;69r\u001b[69;125H"]
[136.209558, "o", "\u001b[2;24r\u001b[2;24r\u001b[125;248s\u001b[1;1H\u001b[19S\u001b[2;24r\u001b[s\u001b[5;125H    ruff format: --- tests/integration/conftest.py\u001b[6;125H    ruff format: +++ tests/integration/conftest.py\u001b[K\u001b[7;125H    ruff format: @@ -30,11 +30,11 @@\u001b[K\u001b[8;125H    ruff format:  def charm():\u001b[K\u001b[9;125H    ruff format:      \"\"\"Return the path of the charm under test.\"\"\"\u001b[K\u001b[10;125H    ruff format:      if \"CHARM_PATH\" in os.environ:\u001b[K\u001b[11;125H    ruff format: -        charm_path = pathlib.Path(os.environ['CHARM_PATH'])\u001b[K\u001b[12;125H    ruff format: +        charm_path = pathlib.Path(os.environ[\"CHARM_PATH\"])\u001b[K\u001b[13;125H    ruff format:          if not charm_path.exists():\u001b[K\u001b[14;125H    ruff format:              raise FileNotFoundError(f\"Charm does not exist: {charm_path}\")\u001b[K\u001b[15;125H    ruff format:          return charm_path\u001b[K\u001b[16;125H    ruff format: -    charm_paths = list(pathlib.Path('.').glob('*.charm'))\u001b[K\u001b[17;125H    ruff format: +    charm_paths = list(pathlib.Path(\".\").glob(\"*.charm\"))\u001b[K\u001b[18;125H    ruff format:      if not charm_paths:\u001b[K\u001b[19;125H    ruff format:          raise FileNotFoundError(\"No .charm file in current directory\")\u001b[K\u001b[20;125H    ruff format:      if len(charm_paths) > 1:\u001b[K\u001b[21;125H    ruff format: --- tests/unit/test_charm.py\u001b[K\u001b[22;125H    ruff format: +++ tests/unit/test_charm.py\u001b[K\u001b[23;125H    ruff format: @@ -13,4 +13,3 @@\u001b[K\u001b[24;125H\u001b[K\u001b[1;69r\u001b[69;125H\u001b[2;24r\u001b[2;24r\u001b[125;248s\u001b[1;1H\u001b[5S\u001b[2;24r\u001b[s\u001b[19;125H    ruff format:      state = testing.State(containers={container})\u001b[20;125H    ruff format:      out = ctx.run(ctx.on.pebble_ready(container), state)\u001b[K\u001b[21;125H    ruff format:      assert out.unit_status == testing.ActiveStatus()\u001b[K\u001