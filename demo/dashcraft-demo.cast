h(\".\").glob(\"*.charm\"))\u001b[48X\r\n    ruff format:      if not charm_paths:\u001b[82X\r\n    ruff format:          raise FileNotFoundError(\"No .charm file in current directory\")\u001b[35X\r\n    ruff format:      if len(charm_paths) > 1:\u001b[77X\r\n    ruff format: --- tests/unit/test_charm.py\u001b[78X\r\n    ruff format: +++ tests/unit/test_charm.py\u001b[78X\u001b[?25l\u001b[?12l\u001b[?25h\u001b[1;69r\u001b[69;125H\u001b[26;45r\u001b[26;45r\u001b[1;123s\u001b[1;1H\u001b[7S\u001b[26;45r\u001b[s\u001b[39;1H    ruff format: @@ -13,4 +13,3 @@\u001b[89X\r\n    ruff format:      state = testing.State(containers={container})\u001b[56X\r\n    ruff format:      out = ctx.run(ctx.on.pebble_ready(container), state)\u001b[49X\r\n    ruff format:      assert out.unit_status == testing.ActiveStatus()\u001b[53X\r\n    ruff format: -\u001b[105X\r\n    ruff format: 3 files would be reformatted, 5 files already formatted\u001b[51X\u001b[45;123H\u001b[1K\u001b[1;69r\u001b[69;125H\u001b[?25l\u001b[?12l\u001b[?25h"]
