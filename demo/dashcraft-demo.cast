[90.867309, "o", "\u001b[18;40r\u001b[18;40r\u001b[1;87s\u001b[1;1H\u001b[14S\u001b[18;40r\u001b[s\u001b[26;1H    ruff format: --- src/charm.py\r\n    ruff format: +++ src/charm.py\u001b[54X\r\n    ruff format: @@ -59,9 +59,7 @@\u001b[53X\r\n    ruff format:          \"\"\"Check whether the workload is ready to use.\"\"\"\u001b[12X\r\n    ruff format:          for name, service_info in self.container.get_services().items\r\n():\u001b[84X\r\n    ruff format:              if not service_info.is_running():\u001b[24X\r\n    ruff format: -                logger.info(\u001b[41X\r\n    ruff format: -                    \"the workload is not ready (service '%s' is not r\r\nunning)\", name\u001b[73X\r\n    ruff format: -                )\u001b[52X\r\n    ruff format: +                logger.info(\"the workload is not ready (service '%s' \r\nis not running)\", name)\u001b[64X\r\n    ruff format:                  return False\u001b[41X\u001b[40;87H\u001b[1K\u001b[1;49r\u001b[49;127H"]
[90.867414, "o", "\u001b[18;40r\u001b[18;40r\u001b[1;87s\u001b[1;1H\u001b[22S\u001b[18;40r\u001b[s\u001b[18;1H    ruff format:          checks = self.container.get_checks(level=ops.pebble.CheckLeve\r\nl.READY)\u001b[79X\r\n    ruff format:          for check_info in checks.values():\u001b[27X\r\n    ruff format: --- tests/integration/conftest.py\u001b[37X\r\n    ruff format: +++ tests/integration/conftest.py\u001b[37X\r\n    ruff format: @@ -30,11 +30,11 @@\u001b[51X\r\n    ruff format:  def charm():\u001b[57X\r\n    ruff format:      \"\"\"Return the path of the charm under test.\"\"\"\u001b[19X\r\n    ruff format:      if \"CHARM_PATH\" in os.environ:\u001b[35X\r\n    ruff format: -        charm_path = pathlib.Path(os.environ['CHARM_PATH'])\u001b[10X\r\n    ruff format: +        charm_path = pathlib.Path(os.environ[\"CHARM_PATH\"])\u001b[10X\r\n    ruff format:          if not charm_path.exists():\u001b[34X\r\n    ruff format:              raise FileNotFoundError(f\"Charm does not exist: {charm_pa\r\nth}\")\u001b[82X\r\n    ruff format:          return charm_path\u001b[44X\r\n    ruff format: -    charm_paths = list(pathlib.Path('.').glob('*.charm'))\u001b[12X\r\n    ruff format: +    charm_paths = list(pathlib.Path(\".\").glob(\"*.charm\"))\u001b[12X\r\n    ruff format:      if not charm_paths:\u001b[46X\r\n    ruff format:          raise FileNotFoundError(\"No .charm file in current directory\"\r\n)\u001b[86X\r\n    ruff format:      if len(charm_paths) > 1:\u001b[41X\r\n    ruff format: --- tests/unit/test_charm.py\u001b[42X\u001b[40;87H\u001b[1K\u001b[1;49r\u001b[49;127H\u001b[18;40r\u001b[18;40r\u001b[1;87s\u001b[1;1H\u001b[6S\u001b[18;40r\u001b[s\u001b[34;1H    ruff format: +++ tests/unit/test_charm.py\r\n    ruff format: @@ -13,4 +13,3 @@\u001b[53X\r\n    ruff format:      state = testing.State(containers={container})\u001b[20X\r\n    ruff format:      out = ctx.run(ctx.on.pebble_ready(container), state)\u001b[13X\r\n    ruff format:      assert out.unit_status == testing.ActiveStatus()\u001b[17X\r\n    ruff format: -\u001b[69X\u001b[40;87H\u001b[1K\u001b[1;49r\u001b[49;127H\u001b[18;40r\u001b[18;40r\u001b[1;87s\u001b[40;87H\n\u001b[18;40r\u001b[s\u001b[39;1H    ruff format: 3 files would be reformatted, 5 files already formatted\u001b[40;87H\u001b[1K\u001b[?25l\u001b[?12l\u001b[?25h\u001b[1;49r\u001b[49;127H"]
