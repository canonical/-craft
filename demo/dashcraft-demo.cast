[45.415843, "o", "\u001b[26;45r\u001b[26;45r\u001b[125;248s\u001b[1;1H\u001b[20S\u001b[26;45r\u001b[s\u001b[26;125H    ruff format:      \"\"\"Return the path of the charm under test.\"\"\"\u001b[K\u001b[27;125H    ruff format:      if \"CHARM_PATH\" in os.environ:\u001b[K\u001b[28;125H    ruff format: -        charm_path = pathlib.Path(os.environ['CHARM_PATH'])\u001b[K\u001b[29;125H    ruff format: +        charm_path = pathlib.Path(os.environ[\"CHARM_PATH\"])\u001b[K\u001b[30;125H    ruff format:          if not charm_path.exists():\u001b[K\u001b[31;125H    ruff format:              raise FileNotFoundError(f\"Charm does not exist: {charm_path}\")\u001b[K\u001b[32;125H    ruff format:          return charm_path\u001b[K\u001b[33;125H    ruff format: -    charm_paths = list(pathlib.Path('.').glob('*.charm'))\u001b[K\u001b[34;125H    ruff format: +    charm_paths = list(pathlib.Path(\".\").glob(\"*.charm\"))\u001b[K\u001b[35;125H    ruff format:      if not charm_paths:\u001b[K\u001b[36;125H    ruff format:          raise FileNotFoundError(\"No .charm file in current directory\")\u001b[K\u001b[37;125H    ruff format:      if len(charm_paths) > 1:\u001b[K\u001b[38;125H    ruff format: --- tests/unit/test_charm.py\u001b[K\u001b[39;125H    ruff format: +++ tests/unit/test_charm.py\u001b[K\u001b[40;125H    ruff format: @@ -13,4 +13,3 @@\u001b[K\u001b[41;125H    ruff format:      state = testing.State(containers={container})\u001b[K\u001b[42;125H    ruff format:      out = ctx.run(ctx.on.pebble_ready(container), state)\u001b[K\u001b[43;125H    ruff format:      assert out.unit_status == testing.ActiveStatus()\u001b[K\u001b[44;125H    ruff format: -\u001b[K\u001b[45;125H\u001b[K\u001b[1;69r\u001b[69;125H\u001b[26;45r\u001b[26;45r\u001b[125;248s\u001b[45;248H\n\u001b[26;45r\u001b[s\u001b[44;125H    ruff format: 3 files would be reformatted, 5 files already formatted\u001b[45;125H\u001b[K\u001b[1;69r\u001b[69;125H\u001b[?25l\u001b[?12l\u001b[?25h"]
